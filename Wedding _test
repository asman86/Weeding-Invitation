    <!-- --- JAVASCRIPT --- -->
    <script>
        // Tarikh Majlis Perkahwinan (Sabtu, 12 Sep 2026 11:00:00)
        const tarikhMajlis = new Date("Sep 12, 2026 11:00:00").getTime();

        // 1. Fungsi Countdown Timer
        const countdownInterval = setInterval(function() {
            const sekarang = new Date().getTime();
            const jarak = tarikhMajlis - sekarang;

            // Kiraan masa untuk Hari, Jam, Minit dan Saat
            const hari = Math.floor(jarak / (1000 * 60 * 60 * 24));
            const jam = Math.floor((jarak % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minit = Math.floor((jarak % (1000 * 60 * 60)) / (1000 * 60));
            const saat = Math.floor((jarak % (1000 * 60)) / 1000);

            // Paparkan hasil dalam elemen masing-masing
            document.getElementById("days").innerText = hari < 10 ? "0" + hari : hari;
            document.getElementById("hours").innerText = jam < 10 ? "0" + jam : jam;
            document.getElementById("minutes").innerText = minit < 10 ? "0" + minit : minit;
            document.getElementById("seconds").innerText = saat < 10 ? "0" + saat : saat;

            // Jika countdown telah tamat
            if (jarak < 0) {
                clearInterval(countdownInterval);
                document.getElementById("days").innerText = "00";
                document.getElementById("hours").innerText = "00";
                document.getElementById("minutes").innerText = "00";
                document.getElementById("seconds").innerText = "00";
            }
        }, 1000);

        // 2. Fungsi Pembuka Undangan & Auto Play Muzik
        const splash = document.getElementById("splash");
        const bgMusic = document.getElementById("bgMusic");
        const musicBtn = document.getElementById("musicBtn");

        function bukaUndangan() {
            splash.classList.add("fade-out");
            // Mainkan muzik latar belakang sejurus kad dibuka
            bgMusic.play().then(() => {
                musicBtn.classList.add("playing");
            }).catch(error => {
                console.log("Auto-play disekat oleh pelayar. Pengguna perlu klik mainkan secara manual.");
            });
            // Mulakan trigger penglihatan tatalan
            triggerScrollAnimations();
        }

        // 3. Fungsi Hidupkan / Matikan Muzik
        function toggleMuzik() {
            if (bgMusic.paused) {
                bgMusic.play();
                musicBtn.classList.add("playing");
                showToast("Muzik Latar Bermula 🎵");
            } else {
                bgMusic.pause();
                musicBtn.classList.remove("playing");
                showToast("Muzik Dijeda 🔇");
            }
        }

        // 4. Kesan Tatalan (Scroll Animation API)
        const animatedElements = document.querySelectorAll('.fade-in-up');

        function triggerScrollAnimations() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('appear');
                    }
                });
            }, {
                threshold: 0.15
            });

            animatedElements.forEach(element => {
                observer.observe(element);
            });
        }

        // 5. Menyembunyikan Pilihan Bilangan Tetamu Sekiranya "Tidak Hadir" Dipilih
        const kehadiranRadios = document.querySelectorAll('input[name="kehadiran"]');
        const bilanganContainer = document.getElementById('bilangan-container');

        kehadiranRadios.forEach(radio => {
            radio.addEventListener('change', function() {
                if (this.value === 'tidak_hadir') {
                    bilanganContainer.style.display = 'none';
                } else {
                    bilanganContainer.style.display = 'block';
                }
            });
        });

        // 6. Fungsi Hantar RSVP Terus Ke Konsol / Sistem Simulasi
        function hantarRSVP(event) {
            event.preventDefault();
            const nama = document.getElementById("nama").value;
            const kehadiran = document.querySelector('input[name="kehadiran"]:checked').value;
            const bilangan = kehadiran === 'hadir' ? document.getElementById("bilangan").value : '0';

            const mesejRSVP = kehadiran === 'hadir' 
                ? `Alhamdulillah, ${nama} mengesahkan kehadiran untuk ${bilangan} orang.`
                : `Terima kasih atas makluman, ${nama} tidak dapat hadir ke majlis.`;

            // Simulasi penghantaran berjaya
            showToast(mesejRSVP);
            
            // Set semula borang
            document.getElementById("rsvpForm").reset();
            bilanganContainer.style.display = 'block';
        }

        // 7. Notifikasi Toast Mesej Kustom
        function showToast(message) {
            const toast = document.getElementById("toast");
            toast.innerText = message;
            toast.classList.add("show");
            
            setTimeout(() => {
                toast.classList.remove("show");
            }, 4000);
        }
    </script>
